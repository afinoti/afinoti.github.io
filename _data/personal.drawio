        <mxCell id="r5x5jFeLZYLGSNL8eORv-1557" value="&lt;ol style=&quot;color: rgb(34, 34, 34); font-family: &amp;quot;SF Pro Display&amp;quot;, -apple-system, BlinkMacSystemFont, Inter, &amp;quot;Segoe UI&amp;quot;, Roboto, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; font-size: 16px; text-align: start; background-color: rgb(255, 255, 255); margin-top: 0px; padding: 0px;&quot;&gt;&lt;li style=&quot;margin: 8px 0px 0px 32px;&quot;&gt;&lt;p style=&quot;box-sizing: border-box; color: rgb(64, 64, 64); line-height: 26px; margin: 0px; padding-left: 4px;&quot;&gt;&lt;b&gt;Multi-terefas&lt;/b&gt;&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;margin: 8px 0px 0px 32px;&quot;&gt;&lt;p style=&quot;box-sizing: border-box; color: rgb(64, 64, 64); line-height: 26px; margin: 0px; padding-left: 4px;&quot;&gt;Quebrar tarefas em menores para terminar os pedaços&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;margin: 8px 0px 0px 32px;&quot;&gt;&lt;p style=&quot;box-sizing: border-box; color: rgb(64, 64, 64); line-height: 26px; margin: 0px; padding-left: 4px;&quot;&gt;Separar tempo de foco e tempo para reuniões/emails&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;" style="text;html=1;strokeColor=none;fillColor=default;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="r5x5jFeLZYLGSNL8eORv-1560">
